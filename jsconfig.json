{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "maxNodeModuleJsDepth": 0,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "api/**/*.js"],
  "exclude": ["node_modules", "dist"]
}
